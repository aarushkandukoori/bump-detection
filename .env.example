# BUMP environment template. Copy to `.env` and adjust as needed.
#
#   cp .env.example .env
#
# docker compose auto-loads `.env` for ${VAR} substitution. The values below are
# the same defaults hard-coded in bump_common.constants, so an empty/absent .env
# still yields a working stack. REDIS_URL / DATABASE_URL are overridden to the
# in-network service names *inside* compose — the values here apply when you run
# a service directly on the host (outside Docker).

# --- Connections -------------------------------------------------------------
# Host-side defaults (services run outside Docker). Inside compose these are
# pinned to redis://redis:6379/0 and postgresql://bump:bump@db:5432/bump.
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://bump:bump@localhost:5432/bump

# --- Signal / framing --------------------------------------------------------
SAMPLE_RATE_HZ=360        # MIT-BIH native rate; the whole pipeline assumes this
FRAME_SAMPLES=8           # samples per ecg:raw frame (~22 ms @ 360 Hz)

# --- Bradycardia rate rule (authoritative alert trigger) ---------------------
BRADY_BPM_THRESHOLD=60    # adult resting bradycardia threshold (bpm)
BRADY_SUSTAIN_SEC=5.0     # low rate must persist this long before alerting
BRADY_MIN_BEATS=4         # ...and cover at least this many qualifying beats

# --- Latency budget ----------------------------------------------------------
LATENCY_BUDGET_MS=250     # sensor emit -> alert publish; asserted by integ test

# --- Model -------------------------------------------------------------------
MODEL_PATH=/models/beat_cnn.onnx   # ONNX artifact path inside the inference container

# --- Ingestion (ECG replay source) ------------------------------------------
SOURCE=mitbih             # 'mitbih' (real record) | 'synthetic'
RECORD=100                # MIT-BIH record id (ignored for synthetic)
SESSION_ID=demo-100       # session key used across streams / DB / DB meta hash
SPEED=1                   # replay speed multiplier (1 = real time)
SYNTHETIC_HR=60           # target HR (bpm) when SOURCE=synthetic; unset -> brady demo
DURATION_SEC=120          # synthetic replay length (mitbih plays/loops the full record)

# --- Prometheus metrics scrape ports ----------------------------------------
INGESTION_METRICS_PORT=9101
INFERENCE_METRICS_PORT=9102
API_METRICS_PORT=9103

# --- Frontend --------------------------------------------------------------
# In compose the SPA is single-origin (nginx proxies /api and /ws to the api
# service) so these stay EMPTY. Only set them for a split-origin dev setup
# (e.g. Vite dev server talking to an API on another host).
VITE_API_BASE=
VITE_WS_BASE=

# --- Advanced: Redis stream name overrides (rarely changed) ------------------
# STREAM_ECG_RAW=ecg:raw
# STREAM_HR_EVENTS=hr:events
# STREAM_ALERTS=alerts:events
