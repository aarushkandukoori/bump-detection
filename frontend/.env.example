# Leave BOTH unset to talk to the same origin (works behind the nginx proxy in
# the Docker image, and via the Vite dev proxy locally).
# For a split dev setup (Vite on 5173, API on 8000), point them at the API:
# VITE_API_BASE=http://localhost:8000
# VITE_WS_BASE=ws://localhost:8000
VITE_API_BASE=
VITE_WS_BASE=
